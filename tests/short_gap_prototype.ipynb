    "import tqdm\n",
    "\n",
    "model.train()\n",
    "model.likelihood.train()\n",
    "training_parameters = model.parameters()\n",
    "lr=0.3\n",
    "optimizer = torch.optim.Adam(training_parameters, lr=lr)\n",
    "mll = gpytorch.mlls.ExactMarginalLogLikelihood(model.likelihood, model)\n",
    "loss_threshold = 0.00001\n",
    "n_epochs = 200\n",
    "verbose=True\n",
    "\n",
