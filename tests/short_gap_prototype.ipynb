   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Scikit-Mobility Processing\n",
    "* Filter by max velocity\n",
    "* Compress points by spatial heuristic\n",
    "* Detect stay locations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {
    "collapsed": true,
    "jupyter": {
     "outputs_hidden": true
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "import skmob.preprocessing.detection\n",
    "import skmob.preprocessing.clustering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Wall time: 7.44 s\n"
     ]
    }
   ],
   "source": [
    "%%time\n",
    "tdf = skmob.TrajDataFrame(mod.data, latitude='orig_lat', longitude='orig_long', datetime='datetime')\n",
    "f_tdf = skmob.preprocessing.filtering.filter(tdf, max_speed_kmh=400, include_loops=True)\n",
    "fc_tdf = skmob.preprocessing.compression.compress(f_tdf, spatial_radius_km=0.2) # vary the spatial radius to see how prediction changes\n",
    "fcs_tdf = skmob.preprocessing.detection.stay_locations(fc_tdf, minutes_for_a_stop=15, spatial_radius_km=0.2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "metadata": {},
