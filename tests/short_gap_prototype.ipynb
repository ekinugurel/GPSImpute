   "source": [
    "# For each row in fc_tdf, check if datetime falls between start and end of a stop in fcsc_tdf, if so, assign the cluster label to the row\n",
    "# If not, assign -1\n",
    "# This is a very slow way to do this, but it works for now\n",
    "\n",
    "# Create a new column in fc_tdf to store the cluster label\n",
    "fc_tdf['cluster_label'] = -1\n",
    "\n",
    "# Loop through each row in fc_tdf\n",
    "for index, row in fc_tdf.iterrows():\n",
    "    # Loop through each row in fcsc_tdf\n",
    "    for index2, row2 in fcsc_tdf.iterrows():\n",
    "        # Check if datetime falls between start and end of a stop in fcsc_tdf\n",
    "        if row['datetime'] >= row2['datetime'] and row['datetime'] <= row2['leaving_datetime']:\n",
    "            # If so, assign the cluster label to the row\n",
    "            fc_tdf.at[index, 'cluster_label'] = row2['cluster']\n",
    "            break\n",
    "\n",
    "\n",
    "fc_tdf.head()"
   ]
